LOCAL_RELAY_HOST=127.0.0.1
LOCAL_RELAY_PORT=8899
LOCAL_RELAY_SIGNING_SECRET=replace-with-the-same-secret-as-worker-relay-auth-secret
LOCAL_RELAY_NO_DATA_TIMEOUT_MS=45000
LOCAL_RELAY_VIDEO_FILTER=scale=1280:720,fps=30
LOCAL_RELAY_VIDEO_BITRATE=2500k
LOCAL_RELAY_VIDEO_MAXRATE=2500k
LOCAL_RELAY_VIDEO_BUFSIZE=5000k
LOCAL_RELAY_X264_PRESET=veryfast
LOCAL_RELAY_X264_PROFILE=main
